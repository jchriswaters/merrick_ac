# Arduino build outputs
mcu/*/build/
tools/build/

# Compiled / signed sketch binaries (re-generated by arduino-cli compile)
*.bin-zsk.bin
*.elf-zsk.bin
*.ino.bin
*.ino.hex
*.ino.map
*.ino.elf
*.ino_debug.elf
*.ino_temp.elf
*.ino_temp.map
*.ino_check.tmp

# Local copies of Arduino package firmwares (vendored elsewhere, for reference only)
tools/zephyr-core.bin
tools/zephyr-core.elf

# Python
__pycache__/
*.pyc
.venv/
venv/

# Desktop HMI — contains controller password
desktop-hmi/config.json

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp
